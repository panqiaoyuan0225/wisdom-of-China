{
  "version": 2,
  "functions": {
    "server.js": {
      "includeFiles": "epub_content/**"
    }
  },
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/sync-stats",
      "methods": ["POST"],
      "dest": "/server.js"
    },
    {
      "src": "/leaderboard/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
