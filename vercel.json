{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "epub_content/**",
      "use": "@vercel/static"
    },
    {
      "src": "images/**",
      "use": "@vercel/static"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/epub_content/(.*)",
      "dest": "/epub_content/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/sync-stats",
      "methods": ["POST"],
      "dest": "/server.js"
    },
    {
      "src": "/load-quiz-data",
      "dest": "/server.js"
    },
    {
      "src": "/load-user-stats",
      "dest": "/server.js"
    },
    {
      "src": "/leaderboard/(.*)",
      "dest": "/server.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
